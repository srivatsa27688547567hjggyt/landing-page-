# ========================
# Echelon Site - .gitignore
# Only site files go to GitHub (for Vercel hosting)
# ========================

# Agent / AI config
.agent/
.gemini/
AGENTS.md
CLAUDE.md

# Root-level non-site folders
/public/
/scripts/
/public/pdf-assets/

# PDF / large assets
*.pdf

# Dependencies
node_modules/

# Next.js build
.next/
out/
build/

# Env files
.env*

# Vercel
.vercel

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# OS files
.DS_Store
Thumbs.db

# TypeScript
*.tsbuildinfo

# Misc
*.pem
/coverage
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
